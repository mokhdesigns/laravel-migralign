#!/bin/sh
# Strip Cursor co-author trailer so cursoragent does not appear as a GitHub contributor.
COMMIT_MSG_FILE=$1
if [ -f "$COMMIT_MSG_FILE" ]; then
  sed -i.bak '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '' '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$COMMIT_MSG_FILE" 2>/dev/null
  rm -f "${COMMIT_MSG_FILE}.bak"
fi
