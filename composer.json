{
    "name": "migralign/laravel-migralign",
    "description": "MigrAlign — align live MySQL tables with Laravel migration schema, safely.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "migrations", "schema", "mysql", "database", "sync"],
    "homepage": "https://github.com/mokhdesigns/laravel-migralign",
    "support": {
        "issues": "https://github.com/mokhdesigns/laravel-migralign/issues",
        "source": "https://github.com/mokhdesigns/laravel-migralign"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/mokhdesigns"
        }
    ],
    "authors": [
        {
            "name": "Mokhtar Ali",
            "email": "mokhdesigns@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/prompts": "^0.1.24|^0.3|^0.4"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MigrAlign\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MigrAlign\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MigrAlign\\MigrAlignServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    }
}
